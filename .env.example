# AISStream.io WebSocket API key — register at https://aisstream.io
AISSTREAM_KEY=replace_me

# Postgres+TimescaleDB (matches docker-compose.yml)
DATABASE_URL=postgresql://shadow:shadow_dev@localhost:5433/shadow

# Logging
LOG_LEVEL=info

# Bounding boxes for AIS subscription (JSON, [[[SW_lat,SW_lon],[NE_lat,NE_lon]], ...])
# Default below = ALL shadow-fleet operational regions (covers every zone in
# packages/api/src/zones.ts):
#   1) NE Atlantic + North Sea + Baltic + Russian Baltic exits + Murmansk/Barents
#   2) Mediterranean + Aegean + Bosphorus + Black Sea (Novorossiysk/Tuapse)
#   3) Red Sea + Bab el-Mandeb + Persian Gulf + Hormuz + Gulf of Oman + Sikka (India)
#   4) Singapore Strait + Malacca
# To run lighter (Baltic + North Sea only) use: [[[53,-10],[66,31]]]
AIS_BBOXES=[[[53,-12],[71,42]],[[30,-6],[47,42]],[[11,42],[30,71]],[[-3,98],[8,108]]]
