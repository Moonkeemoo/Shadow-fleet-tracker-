{
  "name": "oilfront",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "smoke": "bun run packages/api/src/cli/smoke.ts",
    "ingest": "bun run packages/api/src/cli/ingest.ts",
    "load-sanctions": "bun run packages/api/src/cli/load-sanctions.ts",
    "load-opensanctions": "bun run packages/api/src/cli/load-opensanctions.ts",
    "load-ownership": "bun run packages/api/src/cli/load-ownership.ts",
    "load-war-sanctions": "bun run packages/api/src/cli/load-war-sanctions.ts",
    "load-crea": "bun run packages/api/src/cli/load-crea.ts",
    "load-psc": "bun run packages/api/src/cli/load-psc.ts",
    "load-cases": "bun run packages/api/src/cli/load-cases.ts",
    "load-infra": "bun run packages/api/src/cli/load-infra.ts",
    "load-attacks": "bun run packages/api/src/cli/load-attacks.ts",
    "load-infra-strikes": "bun run packages/api/src/cli/load-infra-strikes.ts",
    "test": "node --test packages/api/src/*.test.ts",
    "serve": "bun run packages/api/src/server.ts",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:psql": "docker compose exec postgres psql -U shadow -d shadow"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  }
}
